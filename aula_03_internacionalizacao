-- 2. PADRONIZAÇÃO E LIMPEZA DE DADOS (DATA CLEANING)
-- Ajustando nomes de cidades e equipes para garantir integridade antes da migração.

UPDATE dbo.equipes
SET Central = CASE 
    WHEN TRIM(UPPER(Central)) = 'COLÔNIA' THEN 'Cologne'
    WHEN TRIM(UPPER(Central)) = 'MADRI'   THEN 'Madrid'
    WHEN TRIM(UPPER(Central)) = 'TÓQUIO'  THEN 'Tokyo'
    ELSE Central 
END;


-- 3. MIGRAÇÃO E INTERNACIONALIZAÇÃO PARA O FRANCÊS (SCHEMA MIGRATION)
-- Criando uma nova tabela (equipes_fr) já com os nomes das colunas e dados traduzidos.

SELECT 
    Numero,
    CASE 
        WHEN Nome = 'Onça' THEN 'Panthère' 
        WHEN Nome = 'Flechas' THEN 'Flèches'
        ELSE Nome 
    END AS Nom,
    CASE 
        WHEN Central = 'Tokyo' THEN 'Tokyo'
        WHEN Central = 'Madrid' THEN 'Madrid'
        WHEN Central = 'Cologne' THEN 'Cologne'
        WHEN Central = 'Módena' THEN 'Modène'
        ELSE Central 
    END AS Siège,
    ChefeEquipe AS Patron, -- Renomeação funcional
    [Uni.Potência] AS [Unité_de_Puissance]
INTO dbo.equipes_fr
FROM dbo.equipes;


-- 4. RESOLUÇÃO DE ERROS DE METADADOS (REFATORAÇÃO)
-- Corrigindo o erro Msg 15248 usando referências absolutas para renomear colunas.

-- Renomeando 'Numero' para 'Numéro' (Adicionando o acento francês)
EXEC sp_rename '[dbo].[equipes_fr].[Numero]', 'Numéro', 'COLUMN';

-- Caso o 'Nom' ainda precise de ajuste fino
-- EXEC sp_rename '[dbo].[equipes_fr].[Nom]', 'Nom', 'COLUMN';


-- 5. AUDITORIA E COMPARAÇÃO DE DADOS (QA)
-- Verificando se a tradução e a integridade dos IDs (Numero) coincidem entre as tabelas.

SELECT 
    A.Numero, 
    A.Nome AS [Nome PT], 
    B.Nom AS [Nom FR],
    A.Central AS [Sede Original],
    B.Siège AS [Siège FR]
FROM dbo.equipes A
INNER JOIN dbo.equipes_fr B ON A.Numero = B.Numéro
ORDER BY A.Numero;

