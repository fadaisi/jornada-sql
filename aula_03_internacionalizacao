-- 1. CRIAÇÃO DA ESTRUTURA INICIAL (MODELAGEM)
-- Definindo a tabela base com as colunas Numero, Nome, Central, ChefeEquipe e Uni.Potência.

IF OBJECT_ID('dbo.equipes', 'U') IS NOT NULL DROP TABLE dbo.equipes;

CREATE TABLE dbo.equipes (
    Numero INT PRIMARY KEY,
    Nome VARCHAR(100),
    Central VARCHAR(100),
    ChefeEquipe VARCHAR(100),
    [Uni.Potência] VARCHAR(100)
);

